diff --git a/src/components/Tournament.jsx b/src/components/Tournament.jsx
new file mode 100644
index 0000000..db17ed6
--- /dev/null
+++ b/src/components/Tournament.jsx
@@ -0,0 +1,259 @@
+import { useState, useEffect } from 'react';
+import { useData } from '../lib/DataContext.jsx';
+import {
+  hostTournament, joinByCode, listTeams, createTeam, pickTeam,
+  leaveTournament, myTournaments,
+} from '../lib/tournament.js';
+
+// Tournament — Dock Mode (step 3a): host a tournament, join by code, and pick or
+// create a team. The live leaderboard is step 3b (renders here once you're on a
+// team). State is driven by data.activeTournament = { tournamentId, teamId }.
+//
+// Voice matches the rest of the app — glass panels, eyebrows, btn styles. No new
+// concepts in the shell; this is a new screen slotted into the existing nav.
+
+function fmtDate(iso) {
+  try { return new Date(iso).toLocaleDateString(undefined, { month: 'short', day: 'numeric' }); }
+  catch { return iso; }
+}
+
+// default window: now -> +2 days, as datetime-local strings (local wall time)
+function defaultWindow() {
+  const pad = (n) => String(n).padStart(2, '0');
+  const toLocal = (d) =>
+    `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
+  const start = new Date();
+  const end = new Date(Date.now() + 2 * 864e5);
+  return { start: toLocal(start), end: toLocal(end) };
+}
+
+export default function Tournament({ onToast }) {
+  const { data, updateProfile, runSync } = useData();
+  const active = data.activeTournament || null;
+
+  const [mode, setMode] = useState(null);      // null | 'host' | 'join'
+  const [busy, setBusy] = useState(false);
+  const [mine, setMine] = useState([]);        // my tournaments (list)
+
+  // host form
+  const dw = defaultWindow();
+  const [name, setName] = useState('');
+  const [startsAt, setStartsAt] = useState(dw.start);
+  const [endsAt, setEndsAt] = useState(dw.end);
+  // join form
+  const [code, setCode] = useState('');
+  // team pick/create (shown when in a tournament but teamless)
+  const [teams, setTeams] = useState([]);
+  const [newTeam, setNewTeam] = useState('');
+
+  const toast = (m) => onToast && onToast(m);
+
+  // load my tournaments (for the landing list) when not in one
+  useEffect(() => {
+    if (active) return;
+    let live = true;
+    myTournaments().then((r) => { if (live) setMine(r.tournaments || []); });
+    return () => { live = false; };
+  }, [active]);
+
+  // when in a tournament but teamless, load the team list to pick from
+  useEffect(() => {
+    if (!active || active.teamId) return;
+    let live = true;
+    listTeams(active.tournamentId).then((r) => { if (live) setTeams(r.teams || []); });
+    return () => { live = false; };
+  }, [active]);
+
+  const setActive = (tournamentId, teamId) =>
+    updateProfile((prev) => ({ ...prev, activeTournament: { tournamentId, teamId: teamId || null } }));
+
+  // ---- actions ----
+  const doHost = async () => {
+    if (!name.trim()) { toast('Name your tournament'); return; }
+    setBusy(true);
+    // datetime-local is naive local time; convert to a real instant (ISO/UTC).
+    const startsISO = new Date(startsAt).toISOString();
+    const endsISO = new Date(endsAt).toISOString();
+    if (new Date(endsISO) <= new Date(startsISO)) { setBusy(false); toast('End must be after start'); return; }
+    const r = await hostTournament({ name, startsAt: startsISO, endsAt: endsISO });
+    setBusy(false);
+    if (r.error) { toast(r.error); return; }
+    setActive(r.tournament.id, null);           // host auto-joined, teamless
+    setMode(null);
+    toast(`Hosting “${r.tournament.name}” — code ${r.tournament.join_code}`);
+    runSync && runSync();
+  };
+
+  const doJoin = async () => {
+    if (!code.trim()) { toast('Enter a join code'); return; }
+    setBusy(true);
+    const r = await joinByCode(code);
+    setBusy(false);
+    if (r.error) { toast(r.error); return; }
+    setActive(r.tournament.id, null);           // teamless until they pick
+    setMode(null);
+    toast(`Joined “${r.tournament.name}” — pick your team`);
+    runSync && runSync();
+  };
+
+  const doCreateTeam = async () => {
+    if (!newTeam.trim()) { toast('Name your team'); return; }
+    setBusy(true);
+    const r = await createTeam(active.tournamentId, newTeam);
+    setBusy(false);
+    if (r.error) { toast(r.error); return; }
+    setActive(active.tournamentId, r.team.id);
+    toast(`Team “${r.team.name}” created`);
+    runSync && runSync();
+  };
+
+  const doPickTeam = async (teamId, teamName) => {
+    setBusy(true);
+    const r = await pickTeam(active.tournamentId, teamId);
+    setBusy(false);
+    if (r.error) { toast(r.error); return; }
+    setActive(active.tournamentId, teamId);
+    toast(`You're on ${teamName}`);
+    runSync && runSync();
+  };
+
+  const doLeave = async () => {
+    if (!window.confirm('Leave this tournament? Your logged catches stay in your journal.')) return;
+    setBusy(true);
+    const r = await leaveTournament(active.tournamentId);
+    setBusy(false);
+    if (r.error) { toast(r.error); return; }
+    updateProfile((prev) => ({ ...prev, activeTournament: null }));
+    toast('Left the tournament');
+    runSync && runSync();
+  };
+
+  const resume = (t) => setActive(t.id, t.myTeamId || null);
+
+  // ===========================================================================
+  // RENDER
+  // ===========================================================================
+
+  // --- IN A TOURNAMENT, ON A TEAM: leaderboard placeholder (step 3b) ---
+  if (active && active.teamId) {
+    return (
+      <div className="glass panel">
+        <span className="eyebrow">Tournament</span>
+        <h2 style={{ marginTop: 8 }}>You're in — lines in the water</h2>
+        <p className="muted">
+          Every bass you land counts toward your team's top three. The live
+          leaderboard lands in the next update.
+        </p>
+        <div className="row" style={{ marginTop: 12, gap: 8 }}>
+          <button className="btn danger" onClick={doLeave} disabled={busy}>Leave</button>
+        </div>
+      </div>
+    );
+  }
+
+  // --- IN A TOURNAMENT, TEAMLESS: pick or create a team ---
+  if (active && !active.teamId) {
+    return (
+      <div className="glass panel">
+        <span className="eyebrow">Tournament</span>
+        <h2 style={{ marginTop: 8 }}>Pick your team</h2>
+        <p className="muted">Join a crew or start your own — one team per angler.</p>
+
+        {teams.length > 0 && (
+          <div style={{ marginTop: 12, display: 'grid', gap: 8 }}>
+            {teams.map((t) => (
+              <button key={t.id} className="btn" disabled={busy}
+                onClick={() => doPickTeam(t.id, t.name)} style={{ justifyContent: 'flex-start' }}>
+                🎣 {t.name}
+              </button>
+            ))}
+          </div>
+        )}
+
+        <div style={{ marginTop: 16 }}>
+          <label>
+            Start a new team
+            <input value={newTeam} onChange={(e) => setNewTeam(e.target.value)}
+              placeholder="Team name" />
+          </label>
+          <div className="row" style={{ marginTop: 8, gap: 8 }}>
+            <button className="btn primary" onClick={doCreateTeam} disabled={busy}>Create Team</button>
+            <button className="btn danger" onClick={doLeave} disabled={busy}>Leave</button>
+          </div>
+        </div>
+      </div>
+    );
+  }
+
+  // --- NOT IN A TOURNAMENT: host / join + my tournaments list ---
+  return (
+    <div className="glass panel">
+      <span className="eyebrow">Tournament</span>
+      <h2 style={{ marginTop: 8 }}>Tournament</h2>
+      <p className="muted">
+        Top three bass by total length takes it. Join your crew with a code, or
+        host your own.
+      </p>
+
+      {mode === null && (
+        <div className="row" style={{ marginTop: 12, gap: 8 }}>
+          <button className="btn primary" onClick={() => setMode('join')}>Join with a Code</button>
+          <button className="btn" onClick={() => setMode('host')}>Host a Tournament</button>
+        </div>
+      )}
+
+      {mode === 'join' && (
+        <div style={{ marginTop: 16 }}>
+          <label>
+            Join code
+            <input value={code} onChange={(e) => setCode(e.target.value.toUpperCase())}
+              placeholder="ABC123" maxLength={6} style={{ letterSpacing: '.15em' }} />
+          </label>
+          <div className="row" style={{ marginTop: 8, gap: 8 }}>
+            <button className="btn primary" onClick={doJoin} disabled={busy}>Join</button>
+            <button className="btn" onClick={() => setMode(null)} disabled={busy}>Back</button>
+          </div>
+        </div>
+      )}
+
+      {mode === 'host' && (
+        <div style={{ marginTop: 16, display: 'grid', gap: 10 }}>
+          <label>
+            Tournament name
+            <input value={name} onChange={(e) => setName(e.target.value)}
+              placeholder="Spring Bass Shootout" />
+          </label>
+          <label>
+            Starts
+            <input type="datetime-local" value={startsAt} onChange={(e) => setStartsAt(e.target.value)} />
+          </label>
+          <label>
+            Ends
+            <input type="datetime-local" value={endsAt} onChange={(e) => setEndsAt(e.target.value)} />
+          </label>
+          <div className="row" style={{ gap: 8 }}>
+            <button className="btn primary" onClick={doHost} disabled={busy}>Create</button>
+            <button className="btn" onClick={() => setMode(null)} disabled={busy}>Back</button>
+          </div>
+        </div>
+      )}
+
+      {mode === null && mine.length > 0 && (
+        <div style={{ marginTop: 20 }}>
+          <span className="eyebrow">Your tournaments</span>
+          <div style={{ marginTop: 8, display: 'grid', gap: 8 }}>
+            {mine.map((t) => (
+              <button key={t.id} className="btn" onClick={() => resume(t)}
+                style={{ justifyContent: 'space-between' }}>
+                <span>🏆 {t.name}</span>
+                <span className="muted" style={{ fontSize: '.8rem' }}>
+                  {fmtDate(t.starts_at)}–{fmtDate(t.ends_at)}{t.status === 'closed' ? ' · closed' : ''}
+                </span>
+              </button>
+            ))}
+          </div>
+        </div>
+      )}
+    </div>
+  );
+}
diff --git a/src/lib/tournament.js b/src/lib/tournament.js
index ef44d8a..ace9700 100644
--- a/src/lib/tournament.js
+++ b/src/lib/tournament.js
@@ -161,9 +161,126 @@ export async function flushTournament(data, userId) {
